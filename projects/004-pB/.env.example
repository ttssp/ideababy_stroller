# 决策账本 — 环境变量模板
# 复制此文件为 .env，填入真实值（.env 已 gitignored）
# 注意: 不要在此文件中填入真实 key！

# ── 必填 ──────────────────────────────────────────────────
# Anthropic Claude API key（格式: sk-ant-...）
ANTHROPIC_API_KEY=

# Telegram Bot Token（从 @BotFather 获取，格式: {bot_id}:{token}）
TELEGRAM_BOT_TOKEN=

# ── 可选 ──────────────────────────────────────────────────
# 数据目录（默认 ~/decision_ledger）
# DECISION_LEDGER_HOME=~/decision_ledger

# 测试模式（CI 强制 strict；本地开发可改为 permissive 临时跳过严格校验）
# 架构不变量 #15: CI 默认 strict，T015 ship 前测试标 skip，T015 PR 必须移除 skip
# DECISION_LEDGER_TEST_MODE=strict
