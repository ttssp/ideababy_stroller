{
  "$schema": "https://code.claude.com/schemas/settings.json",

  "model": "opus",
  "subagentModel": "sonnet",

  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "AskUserQuestion",
      "Bash(git:*)",
      "Bash(git worktree:*)",
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(uv:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(go:*)",
      "Bash(cargo:*)",
      "Bash(swift:*)",
      "Bash(rg:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(find:*)",
      "Bash(date:*)",
      "Bash(echo:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr:*)",
      "Bash(gh release:*)",
      "Bash(codex:*)",
      "Agent(conclusion-synthesizer)",
      "Agent(stage1-synthesizer)",
      "Agent(stage2-checkpoint)",
      "Agent(spec-writer)",
      "Agent(task-decomposer)",
      "Agent(parallel-builder)",
      "Agent(security-auditor)",
      "Agent(adversarial-reviewer)",
      "Agent(code-reviewer)",
      "Agent(debate-facilitator)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf .git*)",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(curl * | sh*)",
      "Bash(wget * | sh*)",
      "Edit(.env*)",
      "Edit(*.secrets*)",
      "Edit(specs/**)"
    ]
  },

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "description": "Auto-format on save for JS/TS/JSON/MD",
        "command": "pnpm biome format --write ${CLAUDE_FILE_PATH} 2>/dev/null || true"
      }
    ],
    "Stop": [
      {
        "description": "Remind user to check /cost periodically",
        "command": "true"
      }
    ]
  },

  "attribution": {
    "commit": ""
  },

  "cleanupPeriodDays": 14
}
